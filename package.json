{
  "name": "calendar-server",
  "version": "0.7.2",
  "description": "A self-hosted calendar app with a React frontend and Node.js backend.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "build": "vite build",
    "client": "serve -s dist -l 80",
    "lint": "eslint src/ server.js --config eslint.config.js",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"server.js\"",
    "lint:fix": "eslint src/ server.js --config eslint.config.js --fix"
  },
  "dependencies": {
    "express": "^4.19.2",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-quill": "^2.0.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@tailwindcss/line-clamp": "^0.4.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.4.38",
    "prettier": "^3.8.1",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.4",
    "vite": "^7.3.1"
  }
}
