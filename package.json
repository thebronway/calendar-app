{
  "name": "calendar-server",
  "version": "0.9.6",
  "description": "A self-hosted calendar app with a React frontend and Node.js backend.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "build": "tsc --noEmit && vite build",
    "client": "serve -s dist -l 80",
    "lint": "eslint src/ server.js --config eslint.config.js",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\" \"server.js\"",
    "lint:fix": "eslint src/ server.js --config eslint.config.js --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "dompurify": "^3.0.9",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-quill": "^2.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.10",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.4.38",
    "prettier": "^3.8.1",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0",
    "vite": "^7.3.1"
  }
}
